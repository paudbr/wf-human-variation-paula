  import os
  import numpy as np
  import matplotlib
  os.environ['MPLCONFIGDIR'] = '/tmp'   # fix MPLCONFIGDIR
  matplotlib.use('Agg')
  import matplotlib.pyplot as plt
  import gzip
  import json
  
  # Leer la matriz de deeptools correctamente
  with gzip.open("DEMO_matrix.gz", 'rt') as f:
      header_line = f.readline()
      header = json.loads(header_line.lstrip('@'))
      # Leer el resto como matriz numérica, reemplazando NaN
      data = np.loadtxt(f, dtype=float)
  
  # Los sample_boundaries indican dónde empieza cada muestra
  boundaries = header['sample_boundaries']  # e.g. [0, 200, 400]
  n_bins = boundaries[1] - boundaries[0]
  
  h1 = data[:, boundaries[0]:boundaries[1]]
  h2 = data[:, boundaries[1]:boundaries[2]]
  
  # Reemplazar NaN (deeptools los codifica como 'nan' string a veces)
  h1 = np.where(np.isnan(h1), np.nan, h1)
  h2 = np.where(np.isnan(h2), np.nan, h2)
  
  # Filtrar filas con >50% NaN en cualquiera de los dos haplotipos
  nan_frac = (np.isnan(h1).mean(axis=1) + np.isnan(h2).mean(axis=1)) / 2
  mask = nan_frac < 0.5
  h1_clean = h1[mask]
  h2_clean = h2[mask]
  diff = h1_clean - h2_clean
  
  print(f"Genes totales: {data.shape[0]}, tras filtrado NaN: {h1_clean.shape[0]}")
  
  # Ordenar por diferencia absoluta media
  mean_diff = np.nanmean(np.abs(diff), axis=1)
  order = np.argsort(mean_diff)[::-1]
  
  h1_sorted = h1_clean[order]
  h2_sorted = h2_clean[order]
  diff_sorted = diff[order]
  
  # Plot
  fig, axes = plt.subplots(1, 3, figsize=(14, 10),
                            gridspec_kw={'width_ratios': [1, 1, 1.1]})
  
  # Posiciones del eje X
  n = n_bins
  x_pos    = [0, n//2, n-1]
  x_labels = ['-3kb', 'TSS→TE', '+3kb']
  
  configs = [
      (h1_sorted, 'Haplotipo 1', 'Blues',   0,  1),
      (h2_sorted, 'Haplotipo 2', 'Blues',   0,  1),
      (diff_sorted,'Diferencia (H1-H2)', 'RdBu_r', -1, 1),
  ]
  
  for ax, (mat, title, cmap, vmin, vmax) in zip(axes, configs):
      im = ax.imshow(mat, aspect='auto', cmap=cmap,
                     vmin=vmin, vmax=vmax, interpolation='none')
      ax.set_title(title, fontsize=11, fontweight='bold')
      ax.set_xticks(x_pos)
      ax.set_xticklabels(x_labels, fontsize=8)
      ax.set_yticks([])
      if ax == axes[0]:
          ax.set_ylabel('Genes', fontsize=10)
      label = 'Metilación' if 'Diferencia' not in title else 'ΔMetilación'
      plt.colorbar(im, ax=ax, shrink=0.4, label=label)
  
  plt.suptitle("Metilación 5mC por Haplotipo y ASM: DEMO",
               fontsize=13, fontweight='bold', y=1.01)
  plt.tight_layout()
  plt.savefig("DEMO_diff_heatmap.png", dpi=200, bbox_inches='tight')
  print("Guardado: DEMO_diff_heatmap.png")
